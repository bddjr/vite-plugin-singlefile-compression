{
  "name": "vite-plugin-singlefile-compression",
  "version": "2.1.3",
  "author": "bddjr",
  "license": "MIT",
  "description": "Compress all assets and embeds them into dist/index.html, making it convenient to share as a single HTML file.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "rimraf dist _dist && tsc && node build.js && cd test && node --run build",
    "prepublishOnly": "node --run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bddjr/vite-plugin-singlefile-compression.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "vite-plugin",
    "vite",
    "plugin",
    "SFA",
    "single-file",
    "singlefile",
    "single",
    "compression",
    "compress",
    "gzip",
    "inline",
    "frontend",
    "front-end",
    "js",
    "javascript",
    "css",
    "class",
    "rolldown",
    "rolldown-vite",
    "rollup",
    "vite-plugin-singlefile",
    "vite-plugin-compression",
    "vite-plugin-compression2"
  ],
  "dependencies": {
    "@types/html-minifier-terser": ">=7.0.2",
    "@types/node": "*",
    "base128-ascii": ">=2.1.11",
    "html-minifier-terser": ">=7.2.0",
    "jsdom": ">=28.1.0",
    "mime": ">=4.1.0",
    "mini-svg-data-uri": ">=1.4.4",
    "picocolors": ">=1.1.1",
    "vite": ">=3.0.0"
  },
  "devDependencies": {
    "@bddjr/rimraf": "^0.1.0",
    "@types/jsdom": ">=28.0.0",
    "@types/node": "^22.19.15",
    "esbuild": "^0.27.4",
    "marked": "^17.0.4",
    "rolldown": ">=1.0.0-rc.9",
    "rolldown-plugin-dts": "^0.22.5",
    "rollup": ">=4.59.0",
    "typescript": ">=5.9.3"
  }
}
