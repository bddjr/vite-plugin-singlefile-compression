{
  "name": "vite-plugin-singlefile-compression",
  "version": "2.4.8",
  "author": "bddjr",
  "license": "MIT",
  "description": "Compress all assets and embeds them into dist/index.html, making it convenient to share as a single HTML file.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && node build.js && tsc _dist/templateRaw.ts --ignoreConfig --noEmit && cd website && node --run build",
    "prepublishOnly": "node --run build"
  },
  "homepage": "https://bddjr.github.io/vite-plugin-singlefile-compression/#/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bddjr/vite-plugin-singlefile-compression.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "keywords": [
    "vite-plugin",
    "vite",
    "plugin",
    "SFA",
    "single-file",
    "singlefile",
    "single",
    "compression",
    "compress",
    "compressionstream",
    "decompress",
    "decompression",
    "decompressionstream",
    "compression streams api",
    "compression streams",
    "gzip",
    "deflate",
    "deflate-raw",
    "deflateraw",
    "br",
    "brotli",
    "zstd",
    "zlib",
    "inline",
    "embed",
    "bundle",
    "bundler",
    "frontend",
    "front-end",
    "framework",
    "hmr",
    "dev-server",
    "build-tool",
    "html",
    "htm",
    "htmlmin",
    "js",
    "javascript",
    "css",
    "class",
    "rolldown",
    "rolldown-vite",
    "rollup",
    "min",
    "minification",
    "minifier",
    "minify",
    "optimize",
    "optimizer",
    "pack",
    "packer",
    "vite-plugin-singlefile",
    "vite-plugin-compression",
    "vite-plugin-compression2",
    "html-minifier-terser"
  ],
  "peerDependencies": {
    "@types/node": "*",
    "vite": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/html-minifier-terser": "catalog:",
